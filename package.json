{
	"name": "init-skeleton-typescript",
	"version": "1.0.0",
	"type": "module",
	"description": "A init skeleton for typescript stack",
	"main": "index.js",
	"scripts": {
		"dev": "tsx --watch src/index.ts",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"start": "node dist/index.js",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check ."
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.33.0",
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/node": "^25.6.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
